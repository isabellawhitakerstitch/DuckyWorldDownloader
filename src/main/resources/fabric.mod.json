{
  "schemaVersion": 1,
  "id": "swd",
  "version": "${version}",
  "name": "Ducky World Downloader",
  "description": "Allows you to download worlds from Unstable Events.",
  "authors": ["Duckygang21"],
  "contact": {
    "homepage": "https://github.com/J0KER2J0KER/SimpleWorldDownloader",
    "sources": "https://github.com/J0KER2J0KER/SimpleWorldDownloader",
    "issues": "https://github.com/J0KER2J0KER/SimpleWorldDownloader/issues"
  },
  "license": "GPL-3.0",
  "icon": "assets/swd/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "com.j0ker2j0ker.swd.client.SwdDataGenerator"
    ],
    "client": [
      "com.j0ker2j0ker.swd.client.SwdClient"
    ],
    "modmenu": [
      "com.j0ker2j0ker.swd.client.ModMenuEntry"
    ]
  },
  "mixins": [
    {
      "config": "swd.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "26.1.2"
  }
}
